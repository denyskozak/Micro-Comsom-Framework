{
  "name": "cosmos-framework",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "nx": "nx",
    "serve:shell": "nx serve shell-astro",
    "serve:discovery": "nx serve service-discovery",
    "serve:catalog": "nx serve mf-react-catalog",
    "serve:all": "pnpm serve:platform",
    "build": "nx run-many -t build -p discovery-contracts,discovery-client,service-discovery,mf-react-catalog,mf-header-ssr,mf-footer-ssr,mf-auth-client,shell-astro",
    "check": "nx run-many -t typecheck -p discovery-contracts,discovery-client,service-discovery,mf-react-catalog,mf-header-ssr,mf-footer-ssr,mf-auth-client,shell-astro",
    "serve:header": "nx serve mf-header-ssr",
    "serve:footer": "nx serve mf-footer-ssr",
    "serve:auth": "nx serve mf-auth-client",
    "serve:mfe-infrastructure": "nx serve mfe-infrastructure",
    "serve:platform": "nx run mfe-infrastructure:serve:platform",
    "dev:platform": "pnpm serve:platform",
    "prod:platform": "pnpm build && nx run mfe-infrastructure:serve:platform:prod"
  },
  "devDependencies": {
    "@astrojs/node": "^9.0.0",
    "@astrojs/react": "^4.1.0",
    "@nx/js": "20.4.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "astro": "^5.3.0",
    "nx": "20.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zod": "^3.24.2",
    "eventemitter3": "^5.0.1"
  }
}
